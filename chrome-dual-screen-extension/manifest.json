{
  "manifest_version": 3,
  "name": "Dual Screen Linker (双屏协作)",
  "version": "1.0.1",
  "minimum_chrome_version": "102",
  "description": "专为 Web 应用设计的双屏/多屏协作插件，支持跨屏窗口管理、状态同步与数据通信。",
  "icons": {
    "16": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  },
  "permissions": [
    "system.display",
    "windows",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup/index.html",
    "default_title": "双屏设置 (Dual Screen Settings)",
    "default_icon": {
      "16": "icons/icon.png",
      "48": "icons/icon.png",
      "128": "icons/icon.png"
    }
  }
}
